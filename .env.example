# =====================================================================
# 管理コンソール (ynmo-admin) 環境変数テンプレ
# Bot 側 (line-mvp-api/.env.example) と env 名・値は完全に揃える。
# 実際の値は .env.local に書く（.gitignore 済み）。
# =====================================================================

# ---------------------------------------------------------------------
# Azure Database for MySQL (Flexible Server) — Bot と同じ DB
# ---------------------------------------------------------------------
MYSQL_HOST=tech0-gen11-step4-class-4.mysql.database.azure.com
MYSQL_PORT=3306
MYSQL_USER=student
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=linemvp

# Azure MySQL Flexible Server は SSL 必須。明示的に false にしない限り true。
MYSQL_SSL=true
# 証明書チェーンの厳格な検証。Node.js 標準 CA で検証できないクラス共有 DB は false にする。
# 通信自体は MYSQL_SSL=true なら TLS で暗号化される。
MYSQL_SSL_REJECT_UNAUTHORIZED=false

# ---------------------------------------------------------------------
# ローカル開発時の認証バイパス
# 本番（Azure App Service + Easy Auth）では絶対に設定しないこと。
# true のとき、すべてのリクエストを DEV_AUTH_BYPASS_EMAIL のスタッフでログイン扱いにする。
# ---------------------------------------------------------------------
DEV_AUTH_BYPASS=true
DEV_AUTH_BYPASS_EMAIL=k.yoshida@office-gensen.jp

# ---------------------------------------------------------------------
# UI から呼ぶ API のモード切替（Phase 2 以降で使う）
# true なら public/mocks/*.json を fetch、false なら /api/* を fetch
# ---------------------------------------------------------------------
NEXT_PUBLIC_USE_MOCK=false
